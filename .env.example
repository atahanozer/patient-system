# --- Postgres ---
POSTGRES_USER=patients
POSTGRES_PASSWORD=patients
POSTGRES_DB=patients
# --- Backend ---
DATABASE_URL=postgresql://patients:patients@localhost:5432/patients?schema=public
# DEMO: dev-only placeholder secret (committed so setup is one command). Rotate to
# a strong, secret-managed value in prod — leaking it lets anyone forge valid JWTs.
JWT_SECRET=dev-only-change-me-in-prod
JWT_EXPIRES_IN=1h
# DEMO: chaos simulates a flaky downstream on /patients (latency + ~15% 503s) to
# demo UI resilience. Set CHAOS_ENABLED=false to disable (e2e tests run with it off).
CHAOS_ENABLED=true
CHAOS_FAILURE_RATE=0.15
CORS_ORIGIN=http://localhost:3000
PORT=3001
# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:3001
